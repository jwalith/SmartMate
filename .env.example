# ─── LLM ──────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ─── Slack ────────────────────────────────────────────
SLACK_BOT_TOKEN=xoxb-...
SLACK_SIGNING_SECRET=...
image.png=xapp-...       # only needed for Socket Mode (optional)

# ─── Google OAuth ─────────────────────────────────────
# Path to the credentials.json downloaded from GCP
GOOGLE_CREDENTIALS_FILE=credentials.json
# Where to store the user token after first OAuth login
GOOGLE_TOKEN_FILE=token.json

# ─── App ──────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
# Your ngrok public URL (no trailing slash)
PUBLIC_URL=https://your-ngrok-url.ngrok.io

# ─── Notes DB ─────────────────────────────────────────
NOTES_DB_PATH=notes.db

# ─── Web Search ───────────────────────────────────────
# Get free key at: https://app.tavily.com (1000 searches/month free)
TAVILY_API_KEY=tvly-...

# ─── LangSmith Observability ──────────────────────────
# Get free key at: https://smith.langchain.com → Settings → API Keys
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=lsv2_...
LANGCHAIN_PROJECT=SmartMate
